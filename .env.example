# Sublight WebUI configuration
#
# A token is auto-generated in settings.json on first run.
# These .env values OVERRIDE settings.json when set.

# Auth token — overrides the auto-generated token in settings.json.
# SUBLIGHT_TOKEN=your-secret-token-here

# Server bind address — defaults to 127.0.0.1 (localhost only).
# Set to 0.0.0.0 for LAN access — use a reverse proxy with TLS if exposed.
# HOST=127.0.0.1

# Server port — defaults to 3700.
# PORT=3700
