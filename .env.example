# Sublight WebUI configuration

# Auth token — when set, WebSocket connections require this token.
# Leave empty or remove to disable auth (local dev only).
# SUBLIGHT_TOKEN=your-secret-token-here

# Server bind address — defaults to 0.0.0.0 (all interfaces).
# Set to 127.0.0.1 to restrict to localhost only.
# HOST=0.0.0.0

# Server port — defaults to 3700.
# PORT=3700
